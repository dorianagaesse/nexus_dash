{
  "name": "nexusdash",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:migrate && next dev",
    "build": "next build",
    "start": "npm run db:migrate && next start",
    "lint": "next lint",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:audit:full": "npm audit --json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "db:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@hello-pangea/dnd": "^16.5.0",
    "@prisma/client": "^5.0.0",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emojibase-data": "^17.0.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sanitize-html": "^2.17.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.3",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "ajv": "6.14.0",
    "flatted": "3.4.2",
    "brace-expansion@^1.1.0": "1.1.13",
    "brace-expansion@^2.0.0": "2.0.3",
    "minimatch@^3.0.0": "3.1.5",
    "minimatch@^9.0.0": "9.0.9",
    "picomatch@^2.0.0": "2.3.2",
    "picomatch@^4.0.0": "4.0.4"
  }
}
